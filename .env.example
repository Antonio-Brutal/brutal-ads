# ============================================================================
# Brutal Ads — .env.example   (canonical env names — see docs/11-env-and-keys.md)
# Copy to `.env`, fill in. NEVER commit `.env`. NEVER expose provider keys or
# SUPABASE_SERVICE_ROLE_KEY to the browser. VERIFY each service's docs before coding.
# REQUIRED = happy path needs it. OPTIONAL = feature-gated / has a fallback.
# ============================================================================

# ─── LLM / AGENTS ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # REQUIRED. Whole Creative Studio. console.anthropic.com

# ─── IMAGE PROVIDERS (docs/04) ──────────────────────────────────────────────
BFL_API_KEY=                       # REQUIRED. Primary imagery (FLUX). dashboard.bfl.ai
BFL_REGION=                        # OPTIONAL. "eu" → api.eu.bfl.ai (GDPR/DE tenant)
FAL_KEY=                           # REQUIRED. Aggregator/fallback + Seedream + Seedance + Bria. fal.ai
GEMINI_API_KEY=                    # REQUIRED. Nano-banana edit + Veo video. aistudio.google.com/apikey
IDEOGRAM_API_KEY=                  # OPTIONAL. Fallback in-pixel text. ideogram.ai
RECRAFT_API_KEY=                   # OPTIONAL. Vector/SVG + fallback. recraft.ai/api
OPENAI_API_KEY=                    # OPTIONAL. gpt-image-1.5 diversity fallback. platform.openai.com
SEEDREAM_API_KEY=                  # OPTIONAL. Seedream — sourced via FAL by default.

# ─── EDITOR + RENDER ────────────────────────────────────────────────────────
POLOTNO_API_KEY=                   # REQUIRED. Editor SDK + polotno-node render license. polotno.com/cabinet

# ─── VIDEO / AUDIO (fast-follow, not happy path) ────────────────────────────
KLING_ACCESS_KEY=                  # OPTIONAL(v1). Kling video JWT part 1. klingai.com
KLING_SECRET_KEY=                  # OPTIONAL(v1). Kling video JWT part 2 (server-only).
RUNWAY_API_KEY=                    # OPTIONAL. Runway direct; default route via FAL.
HEYGEN_API_KEY=                    # OPTIONAL (post-MVP). Talking-head avatar.
ELEVENLABS_API_KEY=                # OPTIONAL(v1). VO/SFX/music.
ELEVENLABS_VOICE_ID_DE=            # OPTIONAL(v1). German narrator voice id
ELEVENLABS_VOICE_ID_EN=            # OPTIONAL(v1). English narrator voice id
BRIA_API_KEY=                      # OPTIONAL. Bria direct (bg-remove/expand); default via FAL.

# ─── DATA / AUTH / STORAGE / QUEUE — SUPABASE ───────────────────────────────
SUPABASE_URL=                      # REQUIRED. Project Settings → API
SUPABASE_ANON_KEY=                 # REQUIRED. Client-safe anon key
SUPABASE_SERVICE_ROLE_KEY=         # REQUIRED. SERVER-ONLY — bypasses RLS. Never ship to client.
NEXT_PUBLIC_SUPABASE_URL=          # REQUIRED. = SUPABASE_URL (browser mirror)
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # REQUIRED. = SUPABASE_ANON_KEY (browser mirror)

# ─── ENGAGEMENT ENGINE (services/engine — docs/08) ──────────────────────────
ENGINE_URL=http://localhost:8000   # REQUIRED. FastAPI engine base URL
ENGAGEMENT_BACKEND=saliency        # REQUIRED. "saliency" (commercial) | "tribe_research" (R&D only)
RESEARCH_MODE=false                # REQUIRED. TRIBE (CC-BY-NC) gate — MUST be false on commercial builds
ENGINE_SHARED_SECRET=              # REQUIRED. Shared secret authenticating apps/web ↔ services/engine
RENDER_URL=                        # OPTIONAL. Only if packages/render runs as a separate container

# ─── WEBHOOKS (provider async callbacks: BFL/Fal/Kling) ─────────────────────
WEBHOOK_SIGNING_SECRET=            # REQUIRED. Verify signatures on inbound provider webhooks

# ─── APP ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000 # REQUIRED. Webhooks/callbacks/share links; validate at boot
