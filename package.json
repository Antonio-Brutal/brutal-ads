{
  "name": "brutal-ads",
  "private": true,
  "version": "0.1.0",
  "description": "LinkedIn ad generation platform — build package + monorepo scaffold (no infra wired).",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "engine:dev": "cd services/engine && uvicorn app.main:app --reload --port 8000"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
