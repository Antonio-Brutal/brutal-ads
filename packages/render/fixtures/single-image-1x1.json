{
  "schemaVersion": 1,
  "ratio": "1:1",
  "canvas": { "width": 1200, "height": 1200, "unit": "px", "background": "#0a0a0a" },
  "safeZones": { "profileOverlap": { "top": 0.12, "left": 0 }, "seeMoreFold": 0.85 },
  "layers": [
    { "id": "ly_bg", "type": "image", "name": "Background", "x": 0, "y": 0, "width": 1200, "height": 1200,
      "assetId": null, "src": "fixture://gradient.png", "fit": "cover" },
    { "id": "ly_scrim", "type": "shape", "name": "Scrim", "x": 0, "y": 560, "width": 1200, "height": 640,
      "shape": "rect", "fill": "#0a0a0a", "opacity": 0.55 },
    { "id": "ly_count", "type": "smart", "name": "Proof count", "x": 80, "y": 560, "width": 900, "height": 80,
      "binding": "{{customer_count}}", "template": "{{customer_count}}+ Kanzleien vertrauen Brutal",
      "fallback": "Führende Kanzleien vertrauen Brutal",
      "fontFamily": "Inter", "fontSize": 34, "color": "#cba65e" },
    { "id": "ly_headline", "type": "text", "name": "Headline", "x": 80, "y": 640, "width": 1040, "height": 300,
      "text": "Verträge entwerfen — 40% schneller, ohne Übermut.",
      "fontFamily": "Playfair Display", "fontSize": 76, "fontWeight": 700, "lineHeight": 1.08,
      "color": "#f5f5f0" },
    { "id": "ly_cta", "type": "cta", "name": "CTA", "x": 80, "y": 970, "width": 420, "height": 92,
      "text": "Demo buchen", "style": "solid", "fill": "#b6e64a", "textColor": "#0a0a0a",
      "cornerRadius": 10, "fontFamily": "Inter", "fontSize": 32, "fontWeight": 600 },
    { "id": "ly_logo", "type": "logo", "name": "Logo", "x": 80, "y": 72, "width": 280, "height": 84,
      "assetId": null, "src": "fixture://logo.png", "lockup": "wordmark" },
    { "id": "ly_legal", "type": "legal", "name": "Disclaimer", "x": 80, "y": 1120, "width": 1040, "height": 44,
      "text": "Rechtlicher Hinweis: Ergebnisse ersetzen keine anwaltliche Beratung.",
      "fontFamily": "Inter", "fontSize": 18, "color": "#9a9a92", "requiredBy": "legal_ai_de" }
  ],
  "smartData": {
    "customer_count": { "value": 1200, "display": { "de": "1.200", "en": "1,200" },
      "spoken": { "de": "zwölfhundert", "en": "twelve hundred" } }
  }
}
